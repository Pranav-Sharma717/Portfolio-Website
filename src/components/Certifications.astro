---
import { CenterTitle } from "./UI";
import { CertificationsList } from "../utils/CertificationsList";
import { ExternalLinkIcon } from "lucide-preact";
---

<section id="certifications" class="w-full px-6 py-20 bg-background flex flex-col items-center">
    <CenterTitle title="Certifications" color="primary" />

    <div class="Fade_Up flex flex-col gap-4 w-full max-w-4xl mx-auto mt-12">
        {
            CertificationsList?.map((cert) => (
                <div class="Card_Main w-full flex flex-col sm:flex-row justify-between items-start sm:items-center bg-cardGradient p-6 rounded-[0.4em] shadow-lg border border-[#e5e7eb10] hover:border-[#e5e7eb30] transition-colors gap-4">
                    <div class="flex flex-col gap-1">
                        <h3 class="font-ubuntu text-[1.2em] font-bold tracking-wide">{cert.Name}</h3>
                        <p class="text-[0.9em] text-gray-400">{cert.Issuer} • {cert.Date}</p>
                    </div>
                    {cert.Link !== "#" ? (
                        <a 
                            href={cert.Link} 
                            target="_blank" 
                            rel="noreferrer" 
                            class="flex_center gap-2 px-4 py-2 border border-[#e5e7eb20] hover:bg-[#e5e7eb10] rounded-[0.4em] transition-colors"
                        >
                            <span class="text-[0.9em]">Credential</span>
                            <ExternalLinkIcon size={16} />
                        </a>
                    ) : (
                        <div class="flex_center gap-2 px-4 py-2 border border-[#e5e7eb10] opacity-50 rounded-[0.4em] cursor-not-allowed">
                            <span class="text-[0.9em]">Credential</span>
                            <ExternalLinkIcon size={16} />
                        </div>
                    )}
                </div>
            ))
        }
    </div>
</section>
